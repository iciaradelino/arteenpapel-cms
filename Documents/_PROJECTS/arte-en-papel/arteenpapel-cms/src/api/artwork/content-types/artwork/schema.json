{
  "kind": "collectionType",
  "collectionName": "artworks",
  "info": {
    "singularName": "artwork",
    "pluralName": "artworks",
    "displayName": "Artwork"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Descripcion": {
      "type": "text"
    },
    "Disponibilidad": {
      "type": "enumeration",
      "required": false,
      "default": "Disponible",
      "enum": [
        "Disponible",
        "Vendido"
      ]
    },
    "Imagen": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "Imagen_adicional": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Fecha": {
      "type": "date"
    }
  }
}
